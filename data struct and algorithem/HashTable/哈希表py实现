    "                return v\n",
    "        return default\n",
    "\n",
    "    def remove(self,key):\n",
    "        \"\"\"\n",
    "        删\n",
    "        当传入一个key时,查找元素是否存在,若存在则删除并返回value,不存在则返回报错\n",
    "        \"\"\"\n",
    "        num=self._hash(key)\n",
