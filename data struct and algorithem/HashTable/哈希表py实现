    "            return h%self.capacity\n",
    "        else:\n",
    "            #利用内置哈希函数把key转化为int,在取余\n",
    "            return hash(key)%self.capacity\n",
    "\n",
    "\n",
    "    \"\"\"基本操作\"\"\"\n",
    "    def put(self,key,value):\n",
    "        \"\"\"\n",
    "        增\n",
